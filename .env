# Google Gemini API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Daily Learning Configuration
DAILY_LEARNING_TIME=09:00
USER_PROFICIENCY_LEVEL=intermediate
USER_ROLE_FOCUS=general

