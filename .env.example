GOOGLE_API_KEY=your_api
DAILY_RUN_TIME=14:00

# Confluence Integration (Optional but Recommended)
# For memory/context and response storage
CONFLUENCE_URL=https://company.atlassian.net/wiki
CONFLUENCE_USERNAME=name@mail.com
CONFLUENCE_API_TOKEN=your_api
CONFLUENCE_SPACE=COMMUCRAFT

# Slack Integration (Optional)
# Set SLACK_ENABLED=true and provide credentials to send daily content to Slack
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_THREAD_TS=
